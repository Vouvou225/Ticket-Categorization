# Copy to .env for local development. Never commit the real .env.

# --- Runtime ---
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_TICKET_CHARS=20000
# PORT is read by the container entrypoint and injected by Cloud Run.
# It is not an application setting.
PORT=8080

# --- Routing behavior ---
# suggest = write the AI recommendation as a work note, change nothing (safe).
# enforce = actually set assignment_group and priority.
# Start in suggest, measure with the audit table, then switch to enforce.
ROUTING_MODE=suggest
SKIP_IF_ASSIGNED=true

# --- PII ---
REDACT_PII=false
REDACT_IN_AUDIT=true

# --- Vertex AI ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
# Cheaper for high-volume classification once accuracy is confirmed:
# GEMINI_MODEL=gemini-2.5-flash-lite
VERTEX_TIMEOUT_SECONDS=30
VERTEX_MAX_RETRIES=3

# --- ServiceNow (optional: only for the live webhook/API mode) ---
# Leave blank if you are only using BigQuery batch mode.
SERVICENOW_INSTANCE=
SERVICENOW_USER=
SERVICENOW_PASSWORD=
SERVICENOW_TIMEOUT_SECONDS=30
SERVICENOW_MAX_RETRIES=3
WRITE_TO_SERVICENOW=false

# --- BigQuery batch mode ---
# Reads incidents from a table and writes predictions to another. No ServiceNow.
INCIDENT_SOURCE_TABLE=omes-sdp-p.hub_bld_snow.ab_sn_incident
PREDICTIONS_TABLE=omes-datascience-sbx.Ticket_Categorization.ticket_router_predictions
BATCH_SIZE=200
BATCH_CONCURRENCY=5

# --- Security ---
# Required in production. Shared secret expected in the X-Router-Token header.
WEBHOOK_TOKEN=

# --- Audit (BigQuery) ---
AUDIT_ENABLED=true
BIGQUERY_DATASET=help_desk
BIGQUERY_TABLE=routing_decisions
